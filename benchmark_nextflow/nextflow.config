report.overwrite  = true

workDir        = 'work'
projectDir     = './'
publishDir     = './output/'

params {
    conda_prefix = "\$CONDA_PREFIX"
    threads      = 2
    memory       = 32.GB
    default_conda_env = "envs/benchmarking_env.yml"
    pod5dir = "pod5"
    references = "references.yaml"
    filterChromosomes = true
    tooling_dir = "tooling"
    output_dir = "output"
    toolConfig = [
        dorado: [
            install_dir: "dorado",
            run_flags: "--min-qscore 10",
            dorado_version_map: [
                "4kHz_v4": "dorado-0.5.3",
                "5kHz_v4": "dorado-0.9.1",
                "5kHz_v5": "dorado-0.9.1",
                "5kHz_v5.2": "dorado-1.1.1"
            ],
            dorado_version_aliases: [
                "dorado-0.5.3": "dorado053",
                "dorado-0.9.1": "dorado091",
                "dorado-1.1.1": "dorado111",
                "model_dir": "dorado_models",
            ]
        ],
        rockfish: [
            install_dir: "rockfish",
            executable: "rockfish",
            conda: "rockfish",
            model_dir: "rockfish_models",
            model: "rf_5kHz.ckpt",
            call_flags: "-b 8192 -d 0",
        ],
        deepmod2: [
            install_dir: "deepmod2",
            executable: "deepmod2",
            conda: "deepmod2",
            call_flags: "--device=cuda --batch_size 2048",
        ],
        f5c: [
            install_dir: "f5c",
            executable: "f5c_x86_64_linux_cuda",
            version: "v1.5",
            call_flags: "--cuda-dev-id 0 -x hpc-high -K 2048 -B 40.0M --pore r10",
        ],
        deepplant: [
            install_dir: "DeepPlant",
            executable: "build/DeepPlant",
            conda: "DeepPlant ",
            model_dir: "DeepPlant_models",
            model: "bilstm/",
            call_flags: "51 51 13 8 4 2048",
            aggregation_flags: "--threshold 0.5",
        ],
        deepbam: [
            install_dir: "tools/DeepBAM",
            executable: "cpp/build/DeepBAM",
            conda: "DeepBAM",
            model_dir: "DeepBAM_models",
            model: "LSTM_20240524_newfeature_script_b9_s15_epoch25_accuracy0.9742.pt",
            call_flags: "51 8 4 2048 CG 0",
            aggregation_flags: "--threshold 0.5"
        ],
        samtools: [
            cleanse_flags: "-F 2304 --min-qlen 500"
        ],
        modkit: [
            install_dir: "modkit",
            executable: "modkit",
            version: "0.5.1-rc1"
        ]
    ]
}

process {    
    container = "sowpati/ont-methylation-benchmarking:latest"

    cpus = params.threads
    memory = params.memory
    time = 3.d
    maxForks = 1
    
    resourceLimits = [
        cpus: params.threads,
        memory: params.memory,
        accelerator: 2
    ]

    withLabel: gpu {
        accelerator = 2
        cpus = params.threads
        memory = params.memory
        maxForks = 1
        beforeScript = """
            LOCK_FILE="/tmp/nextflow_gpu_job.lock"
            while ! mkdir "\$LOCK_FILE" 2>/dev/null; do
                echo "Waiting for other GPU job to complete..."
                sleep 10
            done
            trap 'rmdir "\$LOCK_FILE"' EXIT
        """
    }

    withLabel: cpu {
        cpus = params.threads
        memory = params.memory
        maxForks = 4
    }

    withLabel: download {
        cpus   = params.threads
        memory = params.memory
        maxForks = 4
    }

    withLabel: "std_conda" {
        conda = "${projectDir}/${params.default_conda_env}"
    }
    withLabel: 'rockfish' {
        conda = "${params.conda_prefix}/envs/${params.toolConfig.rockfish.conda}"
    }

    withLabel: "deepmod2" {
        // conda = "${params.conda_prefix}/envs/${params.toolConfig.deepmod2.conda}"
        container = null
    }
    
    withName: 'deepbam_call' {
        conda = "${params.conda_prefix}/envs/${params.toolConfig.deepbam.conda}"
    }
    withName: 'deepplant_call' {
        conda = "${params.conda_prefix}/envs/${params.toolConfig.deepplant.conda}"
    }
}

profiles {
    apptainer {
        apptainer {
            enabled = true
            autoMounts = true
            runOptions = '--nv'
            autoMounts = true
        }
        docker.enabled = false
        conda.enabled = false
    }
    singularity {
        apptainer {
            enabled = true
            autoMounts = true
            runOptions = '--nv'
            autoMounts = true
        }
        docker.enabled = false
        conda.enabled = false
    }
    docker {
        docker {
            enabled = true
            runOptions = "--user \$(id -u):\$(id -g) --group-add 100 --gpus all"
        }

        apptainer.enabled = false
        conda.enabled = false
    }
    conda {
        conda.enabled = true
        docker.enabled = false
        apptainer.enabled = false
    }
    cluster {
        process.maxForks = 2
        process.cpus=25
        process.executor="pbs"
        process.queue="cpu-q"
        process.memory=110.GB
        process.time=20.d
        process.clusterOptions=""
        process.resourceLimits = [
            memory: 250.GB,
            cpus: 56,
            time: 30.d,
            accelerator: 2
        ]
    }
}
