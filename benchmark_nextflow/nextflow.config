report.overwrite  = true

workDir        = 'work'
projectDir     = './'
publishDir     = './output/'

params {
    conda_prefix = "\$CONDA_PREFIX"
}

process {
    maxForks = 2
    cpus = 20
    mem = 100.GB
    time = 3.d
    container = "pruned"
    
    resourceLimits: [
        memory: 250.GB,
        cpus: 80,
        accelerator: 2,
    ]
    
    withLabel: gpu {
        accelerator = 2
        cpus = 40
        memory = 128.GB
        maxForks = 1
    }

    withLabel: cpu {
        cpus = 20
        memory = 100.GB
        maxForks = 4
    }

    withLabel: download {
        cpus = 5
        memory = 50.GB
    }

    withLabel: "std_conda" {
        conda = "workflow/envs/benchmarking_env.yml"
    }
    withName: "mosdepth" {
        container = "quay.io/biocontainers/mosdepth:0.3.3--h37c5b7d_2"
    }
    withName: "mosdepth" {
        container = "quay.io/biocontainers/mosdepth:0.3.3--h37c5b7d_2"
    }
    withLabel: 'rockfish' {
        conda = "${params.conda_prefix}/envs/${params.toolConfig.rockfish.conda}"
    }
    withLabel: "deepmod2" {
        conda = "${params.conda_prefix}/envs/${params.toolConfig.deepmod2.conda}"
    }
    
    withName: 'deepbam_call' {
        conda = "${params.conda_prefix}/envs/${params.toolConfig.deepbam.conda}"
    }
    withName: 'deepplant_call' {
        conda = "${params.conda_prefix}/envs/${params.toolConfig.deepplant.conda}"
    }
}

profiles {
    apptainer {
        apptainer {
            enabled = true
            autoMounts = true
            runOptions = '--nv'
            autoMounts = true
        }
        docker.enabled = false
        conda.enabled = false
        process.container = "sowpati/ont-methylation-benchmarking:latest"
    }
    singularity {
        apptainer {
            enabled = true
            autoMounts = true
            runOptions = '--nv'
            autoMounts = true
        }
        docker.enabled = false
        conda.enabled = false
        process.container = "sowpati/ont-methylation-benchmarking:latest"
    }
    docker {
        docker {
            enabled = true
            runOptions = "--user \$(id -u):\$(id -g) --group-add 100 --gpus all"
            // runOptions = "--gpus all"
        }
        apptainer.enabled = false
        conda.enabled = false
        process.container = "sowpati/ont-methylation-benchmarking:latest"
    }
    conda {
        conda.enabled = true
        docker.enabled = false
        apptainer.enabled = false
    }
    cluster {
        process.queueSize = 2
        process.cpus=25
        process.executor="pbs"
        process.queue="cpu-q"
        process.memory=110.GB
        process.time=20.d
        process.clusterOptions=""
        process.resourceLimits = [
            memory: 250.GB,
            cpus: 56,
            time: 30.d,
            accelerator: 2
        ]
    }
}
