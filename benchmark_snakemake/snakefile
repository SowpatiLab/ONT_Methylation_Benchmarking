import os, sys, glob
from pathlib import Path

include: 'getters.smk'

rule all:
    input: 
        dorado=fetch_dorado_list(),
        nanoq=fetch_qc_tool_list('nanoq'),
        nanostat=fetch_qc_tool_list('nanostat'),
        nanoplot=fetch_qc_tool_list('nanoplot'),
        mosdepth=fetch_qc_tool_list('mosdepth'),
        rockfish=fetch_rockfish_list(),
        f5c_str=fetch_f5c_stranded_list(),
        f5c=fetch_f5c_list(),
        DeepBAM=fetch_deepbam_list(),
        DeepPlant=fetch_deepplant_list(),
        DeepMOD2_transformer=fetch_deepmod2_transformer_list(),
        DeepMOD2_bilstm=fetch_deepmod2_bilstm_list(),

rule download_dorado_models:
    output: directory(f"{DORADO_MODELS}/{{model}}")
    params: 
        dorver=get_dorver_from_model,
        rerio_exec=RERIO_RUN,
        rerio_cache=subpath(Path(RERIO_RUN), parent=True)
    shell: """
        if  [ -f /.dockerenv ];
        then
            dorado_exec={params.dorver};
        elif [ -d "/.singularity.d" ];
        then
            dorado_exec={params.dorver};
        else
            dorado_exec={DORADO_HOME}/{params.dorver}/bin/dorado;
            rerio_exec={params.rerio_exec}
        fi;

        [ ! -d {DORADO_MODELS} ] && mkdir -p {DORADO_MODELS};
        if [[ {params.dorver} != 'rerio' ]]; then
            $dorado_exec download --model {wildcards.model} --models-directory {DORADO_MODELS};
        else
            if  [ -f /.dockerenv ];
            then
                cp -r /tooling/rerio/dorado_models/ {DORADO_MODELS};
                cd {DORADO_MODELS};
                cp /tooling/rerio/download_model.py ./;
                ./download_model.py --dorado;
                mv dorado_models/*/ ./;
                rm -r dorado_models download_model.py;
                cd -
            elif [ -d "/.singularity.d" ];
            then
                cp -r /tooling/rerio/dorado_models/ {DORADO_MODELS};
                cd {DORADO_MODELS};
                cp /tooling/rerio/download_model.py ./;
                ./download_model.py --dorado;
                mv dorado_models/*/ ./;
                rm -r dorado_models download_model.py;
                cd -
            else
                $rerio_exec --dorado;
                cp -r {params.rerio_cache}/*/ {DORADO_MODELS};
            fi;
        fi
    """

for mode in ['move', 'mod']:
    def dorado_setup():
        if NRUNS==0:
            return [
                config['pod5dir'] + f"/{{experiment}}_{{sr}}kHz",
                config['output_dir'] + "/" + f"bam/sorted_{mode}/{{experiment}}_{{sr}}kHz_{{acc}}_v{{ver}}{{mod}}.bam",
                f"log/dorado_{mode}/{{experiment}}_{{sr}}kHz_{{acc}}_v{{ver}}{{mod}}.log",
            ]
        else: 
            return [
                config['pod5dir'] + f"/{{experiment}}_run{{run}}_{{sr}}kHz",
                config['output_dir'] + "/" + f"bam/sorted_sep_{mode}/{{experiment}}_run{{run}}_{{sr}}kHz_{{acc}}_v{{ver}}{{mod}}.bam",
                f"log/dorado_{mode}/{{experiment}}_run{{run}}_{{sr}}kHz_{{acc}}_v{{ver}}{{mod}}.log"
            ]

    rule:
        name:  f"dorado_{mode}"
        input:  
            pod5=dorado_setup()[0],
            model=fetch_model,
            mod_model=lambda w: fetch_mod_model if w.mod!="" else []
        output: dorado_setup()[1]
        log:    dorado_setup()[2]
        threads: 40
        resources:
            gpu=2
        params:
            ref=getRef,
            dorver=select_dorado,
            run_flags=config['toolConfig']['dorado']['run_flags'],
            mod_flag="--modified-bases-models" if mode=="mod" else "--emit-moves"
        conda: config['default_conda_env']
        shell: sh("""
            if  [ -f /.dockerenv ];
            then
                exec={params.dorver};
            elif [ -d "/.singularity.d" ];
            then 
                exec={params.dorver};
            else
                exec={DORADO_HOME}/{params.dorver}/bin/dorado;
            fi;

            ${{exec}} basecaller \
            {input.model} {input.pod5} {params.mod_flag} {input.mod_model} \
            {params.run_flags} \
            --reference {params.ref} | {SAMTOOLS} sort -O BAM -@ {threads} -o {output} --write-index
        """)

if NRUNS!=0:
    rule merge:
        input:  expand(config['output_dir'] + "/" + "bam/sorted_sep_{{doradomode}}/{{experiment}}_run{run}_{{sr}}kHz_{{acc}}_v{{ver}}{{mod}}.bam", run=RUNS)
        output: config['output_dir'] + "/" + "bam/sorted_{doradomode}/{experiment}_{sr}kHz_{acc}_v{ver}{mod}.bam"
        threads: 40
        conda: config['default_conda_env']
        shell: sh("{SAMTOOLS} merge -@ {threads} -O BAM -o {output} {input} --write-index")

rule cleanse_bams:
    input:  config['output_dir'] + "/" + "bam/sorted_{doradomode}/{sample}.bam"
    output: config['output_dir'] + "/" + "bam/sorted_{doradomode}_cleansed/{sample}.cleansed.bam"
    log:    "log/{doradomode}_cleanser/{sample}.log"
    threads: 20
    conda: config['default_conda_env']
    params: 
        std_chroms=fetch_chrom_str,
        cleanse_flags=config['toolConfig']['samtools']['cleanse_flags']
    shell:  sh("{SAMTOOLS} view {input} {params.std_chroms} -hbo {output} -@ {threads} {params.cleanse_flags} --write-index")

rule index_fasta:
    input:  '{reference}.fa'
    output: '{reference}.genome'
    shell:  "{SAMTOOLS} faidx {input}; cut -f 1,2 {input}.fai > {output}"

def redundant_mod(wildcards):
    return {
        '_5mC'  : '_5mC',
        '_5hmC' : '_5mC',
        '_5mCG' : '_5mCG',
        '_5hmCG': '_5mCG',
        '_4mC'  : '_4mC',
        '_6mA'  : '_6mA',
    }[wildcards.mod]

def modkit_set_params(wildcards):
    if wildcards.mod in ['_5hmC', '_5hmCG']:
        return '--ignore m'
    else: 
        return "--ignore h"
    
rule modkit:
    input:  expand(config['output_dir'] + "/" + "bam/sorted_mod_cleansed/{{experiment}}_{{sr}}kHz_{{acc}}_v{{ver}}{mod}.cleansed.bam", mod=lambda x: redundant_mod(x))
    output: config['output_dir'] + "/" + "tool_out/dorado/pileup/{experiment}_{sr}kHz_{acc}_v{ver}{mod}.cleansed.bed"
    threads: 40
    log:    "log/modkit_pileup/{experiment}_{sr}kHz_{acc}_v{ver}{mod}.log"
    conda: config['default_conda_env']
    params: 
        ref=getRef,
        set_params=modkit_set_params
    shell: sh("{MODKIT} pileup {input} {output} -t {threads} --ref {params.ref} {params.set_params}")

rule addfasta:
    input:  
        bed=config['output_dir'] + "/" + "tool_out/dorado/pileup/{experiment}_{sr}kHz_{acc}_v{ver}{mod}.cleansed.bed",
        fasta=lambda wildcards: getRef(wildcards),
        genome=lambda wildcards: re.sub(r'.fa(sta|)', '.genome', getRef(wildcards))
    output: config['output_dir'] + "/" + "tool_out/dorado/ref/{experiment}_{sr}kHz_{acc}_v{ver}{mod}.cleansed.ref.bed"
    threads: 20
    conda: config['default_conda_env']
    log: "log/modkit_ref/{experiment}_{sr}kHz_{acc}_v{ver}{mod}.log"
    shell: sh("{BEDTOOLS} slop -i {input.bed} -g {input.genome} -l 5 -r 11 -s | {BEDTOOLS} getfasta -fi {input.fasta} -bed - -tab -s | cut -f 2 | paste -d '\t'  {input.bed} - > {output}")

rule modkit_add_metadata:
    input:  config['output_dir'] + "/" + "tool_out/dorado/ref/{experiment}_{sr}kHz_{acc}_v{ver}{mod}.cleansed.ref.bed"
    output: config['output_dir'] + "/" + "meta/dorado/{experiment}_{sr}kHz_{acc}_v{ver}{mod}.cleansed.ref.std.tsv"
    log: "log/metadata/{experiment}_{sr}kHz_{acc}_v{ver}{mod}.log"
    threads: 20
    conda: config['default_conda_env']
    params: script_dir=Path(workflow.basedir) / "scripts_common"
    shell: "python {params.script_dir}/modkit_consolidate.py {input} {output}"

