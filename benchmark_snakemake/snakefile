rule bam_to_fastq:
    input:  config['output_dir'] + "/" + "bam/sorted_move_cleansed/{experiment}_{sr}kHz_{acc}_v{ver}.cleansed.bam"
    output: config['output_dir'] + "/" + "intermediary/fastq/{experiment}_{sr}kHz_{acc}_v{ver}.fastq"
    threads: 10
    log:  "log/bam_to_fastq/{experiment}_{sr}kHz_{acc}_v{ver}.log"
    conda: config['default_conda_env']
    shell: sh("{SAMTOOLS} fastq -@ {threads} {input} -0 {output}")

rule nanoq:
    input:  config['output_dir'] + "/" + "intermediary/fastq/{experiment}_{sr}kHz_{acc}_v{ver}.fastq"
    output: config['output_dir'] + "/" + "qc/nanoq/{experiment}_{sr}kHz_{acc}_v{ver}.nanoq"
    log:    "log/nanoq/{experiment}_{sr}kHz_{acc}_v{ver}.log"
    threads: 10
    conda: config['default_conda_env']
    shell:  sh("nanoq -s -i {input} > {output}" )

rule nanostat:
    input:  config['output_dir'] + "/" + "bam/sorted_move_cleansed/{experiment}_{sr}kHz_{acc}_v{ver}.cleansed.bam"
    output: config['output_dir'] + "/" + "qc/nanostat/{experiment}_{sr}kHz_{acc}_v{ver}.nanostat"
    log:    "log/nanostat/{experiment}_{sr}kHz_{acc}_v{ver}.log"
    threads: 10
    conda: config['default_conda_env']
    shell:  sh("NanoStat --bam {input} > {output}") 

rule nanoplot:
    input:  config['output_dir'] + "/" + "bam/sorted_move_cleansed/{experiment}_{sr}kHz_{acc}_v{ver}.cleansed.bam"
    output: directory(config['output_dir'] + "/" + "qc/nanoplot/{experiment}_{sr}kHz_{acc}_v{ver}")
    threads: 20
    conda: config['default_conda_env']
    shell: sh('''
        mkdir -p {output}; NanoPlot --no_static --only-report --minqual 0 --bam {input} --raw --tsv_stats -t {threads} -o {output}
    ''')

rule mosdepth:
    input:  config['output_dir'] + "/" + "bam/sorted_move_cleansed/{experiment}_{sr}kHz_{acc}_v{ver}.cleansed.bam"
    output: directory(config['output_dir'] + "/" + "qc/mosdepth/{experiment}_{sr}kHz_{acc}_v{ver}")
    log:    "log/mosdepth/{experiment}_{sr}kHz_{acc}_v{ver}.log"
    threads: 10
    conda: 'env/mosdepth_env.yml'
    params: basename=subpath(output[0], basename=True)
    shell: ntsh("mkdir -p {output}; {TIME} mosdepth -t {threads} {output}/{params.basename} {input}")

